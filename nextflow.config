manifest {
    name            = 'nf-se-to-pe'
    author          = 'Biocentric'
    homePage        = 'https://github.com/Biocentric/nf-se-to-pe'
    description     = 'Convert single-end FASTQ into simulated paired-end by half-split + reverse-complement with optional R2 jitter.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}

params {
    input             = null
    outdir            = './results'
    gap_size          = 10
    jitter_max        = 3
    seed              = 42
    min_mate_len      = 30
    multiqc_config    = null
    singularity_cache_dir = null
    publish_dir_mode  = 'copy'
    max_memory        = '32.GB'
    max_cpus          = 8
    max_time          = '24.h'
    monochrome_logs   = false
    help              = false
    validate_params   = true
    tracedir          = "${params.outdir}/pipeline_info"
}

process.resourceLimits = [
    cpus:   params.max_cpus   as int,
    memory: params.max_memory as nextflow.util.MemoryUnit,
    time:   params.max_time   as nextflow.util.Duration
]

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    debug { process.beforeScript = 'echo $HOSTNAME' }

    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = params.singularity_cache_dir ?: "${System.getenv('HOME') ?: '.'}/.singularity-cache/se-to-pe"
        singularity.pullTimeout = '60m'
        docker.enabled         = false
        conda.enabled          = false
    }
    test      { includeConfig 'conf/test.config'      }
}

env {
    PYTHONNOUSERSITE = 1
}

process.shell = ['/bin/bash', '-euo', 'pipefail']

timeline { enabled = true; file = "${params.tracedir}/execution_timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.tracedir}/execution_report.html";   overwrite = true }
trace    { enabled = true; file = "${params.tracedir}/execution_trace.txt";     overwrite = true }
dag      { enabled = true; file = "${params.tracedir}/pipeline_dag.html";       overwrite = true }
